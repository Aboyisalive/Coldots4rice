env = GTK_THEME,WhiteSur-Dark
env = QT_QPA_PLATFORMTHEME,qt5ct
env = QT_QPA_PLATFORMTHEME,qt6ct

# gsettings bir komut olduğu için 'exec-once' ile sistem açılırken bir kez çalıştırılmalı:
exec-once = gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

source = ~/.config/hypr/configs/monitors.conf
source = ~/.config/hypr/configs/autostart.conf
source = ~/.config/hypr/configs/env.conf
source = ~/.config/hypr/configs/hyprcolors.conf
source = ~/.config/hypr/configs/animations.conf
source = ~/.config/hypr/configs/general.conf
source = ~/.config/hypr/configs/input.conf
source = ~/.config/hypr/configs/keybinds.conf
source = ~/.config/hypr/configs/windowrule.conf
source = ~/.config/hypr/configs/debug.conf


#nvidia
decoration {
    # ... diğer ayarların
    screen_shader = /home/leyzs/.config/hypr/shaders/vibrance.glsl
}1
