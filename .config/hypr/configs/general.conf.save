
# Görsel ayarların (Buraya dokunmadık, aynen kalıyor)
decoration {
    rounding = 10

    blur {
        enabled = true
        size = 3
        passes = 2
        new_optimizations = true
        ignore_opacity = true
        xray = false
    }

    # YENİ VERSİYON GÖLGE AYARI ✨
    shadow {
        enabled = true
        range = 10
        render_power = 3
        color = rgba(1a1a1aee)
    }
}
